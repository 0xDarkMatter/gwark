# Gmail MCP Server Environment Configuration
# Copy this file to .env and fill in your values

# Server Configuration
SERVER_NAME="Gmail MCP Server"
SERVER_VERSION="0.1.0"
LOG_LEVEL="INFO"  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# OAuth2 Configuration
OAUTH2_CREDENTIALS_PATH="config/oauth2_credentials.json"
TOKEN_STORAGE_PATH="data/tokens"
ENCRYPTION_KEY=""  # Leave empty to auto-generate, or provide a Fernet key

# Cache Configuration
CACHE_ENABLED="true"
CACHE_DB_PATH="data/cache/email_cache.db"
CACHE_TTL_SECONDS="3600"  # 1 hour
MAX_CACHE_SIZE_MB="500"

# Gmail API Configuration
DEFAULT_PAGE_SIZE="100"
MAX_BATCH_SIZE="50"
MAX_RESULTS_PER_SEARCH="500"

# Rate Limiting (Google Workspace defaults)
# Project: 1,200,000 queries/min | Per-user: 15,000 queries/min
RATE_LIMIT_ENABLED="true"
RATE_LIMIT_PER_SECOND="250"
RATE_LIMIT_BURST="100"

# Multi-Account Support
DEFAULT_ACCOUNT_ID="primary"
MAX_ACCOUNTS="5"

# Performance
ENABLE_ASYNC="true"
CONNECTION_POOL_SIZE="10"
MAX_CONCURRENT="50"  # Parallel API operations
TIMEOUT_SECONDS="30"

# Development
DEBUG_MODE="false"
MOCK_GMAIL_API="false"
